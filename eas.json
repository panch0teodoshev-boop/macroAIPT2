{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "ios": { "simulator": true }
    },
    "production": {
      "autoIncrement": true,
      "ios": { "resourceClass": "m-medium" }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "ТВОЯТ-APPLE-ID@email.com",
        "ascAppId": "APP-STORE-CONNECT-APP-ID",
        "appleTeamId": "ТВОЯТ-TEAM-ID"
      }
    }
  }
}
